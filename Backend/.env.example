# Core
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
TIME_ZONE=UTC

# Database
# Use local SQLite for fast local development
USE_LOCAL_SQLITE=true

# PostgreSQL fallback values (used when USE_LOCAL_SQLITE=false)
DB_NAME=pantry_manager
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=disable
DB_CONNECT_TIMEOUT=10
DB_CONN_MAX_AGE=600
DB_CONN_HEALTH_CHECKS=true

# Frontend origins (local)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cookie profile (local same-site)
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
CSRF_COOKIE_HTTPONLY=false

# Production cross-origin HTTPS profile (example)
# DEBUG=False
# CORS_ALLOWED_ORIGINS=https://your-frontend-domain
# CSRF_TRUSTED_ORIGINS=https://your-frontend-domain
# SESSION_COOKIE_SAMESITE=None
# CSRF_COOKIE_SAMESITE=None
# SESSION_COOKIE_SECURE=true
# CSRF_COOKIE_SECURE=true
