# Local development (recommended): use same-origin /api via Vite proxy
VITE_API_URL=
VITE_DEV_PROXY_TARGET=http://localhost:8000

# Local proxy to Railway backend example
# VITE_DEV_PROXY_TARGET=https://your-backend-domain

# Local direct backend origin (cross-origin)
# VITE_API_URL=http://localhost:8000

# Production example (deployed frontend)
# VITE_API_URL=https://your-backend-domain
